<Window x:Class="SyslogHmi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SyslogHmi.Views"
        xmlns:converters="clr-namespace:SyslogHmi.Converters"
        xmlns:viewmodels="clr-namespace:SyslogHmi.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel, IsDesignTimeCreatable=False}"
        Title="SyslogHmi - Syslog Viewer" Height="600" Width="1200"
        Background="#F0F0F0">
    <Window.Resources>
        <converters:FriendlyColorNameToBrushConverter x:Key="ColorNameToBrushConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="#2D3436" Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Title -->
                <TextBlock Text="SyslogHmi" FontSize="18" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,30,0"/>

                <!-- TCP Port -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="TCP Port:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="70" Padding="5" VerticalAlignment="Center" 
                             Text="{Binding SelectedTcpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- UDP Port -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock Text="UDP Port:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Width="70" Padding="5" VerticalAlignment="Center" 
                             Text="{Binding SelectedUdpPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Start Button -->
                <Button Content="START" Background="#27AE60" Foreground="White" 
                        Padding="15,8" Margin="0,0,5,0" FontWeight="Bold"
                        Command="{Binding StartListeningCommand}"/>

                <!-- Stop Button -->
                <Button Content="STOP" Background="#E74C3C" Foreground="White" 
                        Padding="15,8" Margin="0,0,5,0" FontWeight="Bold"
                        Command="{Binding StopListeningCommand}"/>

                <!-- Clear Button -->
                <Button Content="CLEAR" Background="#3498DB" Foreground="White" 
                        Padding="15,8" Margin="0,0,5,0" FontWeight="Bold"
                        Command="{Binding ClearMessagesCommand}"/>

                <!-- Send Random Syslog Button -->
                <Button Content="SEND RANDOM" Background="#E67E22" Foreground="White" 
                        Padding="15,8" Margin="0,0,5,0" FontWeight="Bold"
                        Command="{Binding SendRandomSyslogCommand}"/>

                <!-- Exit Button -->
                <Button Content="EXIT" Background="#95A5A6" Foreground="White" 
                        Padding="15,8" FontWeight="Bold"
                        Command="{Binding ExitCommand}"/>

                <!-- Status -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="White" 
                          VerticalAlignment="Center" Margin="30,0,0,0" FontSize="11"/>

                <!-- Message Count -->
                <TextBlock Foreground="White" VerticalAlignment="Center" Margin="30,0,0,0">
                    <Run Text="Total: "/>
                    <Run Text="{Binding TotalMessagesReceived}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <TabControl>
                <!-- Messages Tab -->
                <TabItem Header="Messages" Background="White">
                    <views:MessagesView/>
                </TabItem>

                <!-- Color Rules Tab -->
                <TabItem Header="Color Rules" Background="White">
                    <views:ColorRulesView/>
                </TabItem>

                <!-- SQL Analysis Tab -->
                <TabItem Header="SQL Analysis" Background="White">
                    <views:SqlAnalysisView/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,1,0,0" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " FontWeight="Bold"/>
                <TextBlock Text="{Binding StatusMessage}"/>
                <TextBlock Text=" | " Margin="10,0"/>
                <TextBlock>
                    <Run Text="Listening: "/>
                    <Run Text="{Binding IsListening}"/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
