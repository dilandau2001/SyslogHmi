<UserControl x:Class="SyslogHmi.Views.MessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.expression/blend/2008"
             xmlns:converters="clr-namespace:SyslogHmi.Converters"
             xmlns:culture="clr-namespace:System.Globalization;assembly=System.Runtime"
             mc:Ignorable="d"
             Background="#F5F6FA" d:DesignWidth="1000" d:DesignHeight="700"
             xmlns:vm="clr-namespace:SyslogHmi.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter"/>
        <converters:SingleLineConverter x:Key="SingleLineConverter" />
		<converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="150" MaxWidth="600"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <!-- Lateral Izquierdo - Filtros Mejorados -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="FILTERS" FontSize="14" FontWeight="Bold" Margin="0,5,0,15" Foreground="#2D3436"/>

                    <!-- Hostname Filter -->
                    <TextBlock Text="Hostname:" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" Foreground="#7F8C8D"/>
                    <TextBox Text="{Binding FilterViewModel.HostnameFilter, UpdateSourceTrigger=PropertyChanged,Mode=TwoWay, Delay=400}"
                             Padding="8" Margin="0,0,0,12"
                             BorderBrush="#E0E0E0"
                             AcceptsReturn="True"
                             Height="60"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"/>

                    <!-- AppName Filter -->
                    <TextBlock Text="Aplication:" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" Foreground="#7F8C8D"/>
                    <TextBox Padding="8" Margin="0,0,0,12" BorderBrush="#E0E0E0"
                             Text="{Binding FilterViewModel.AppNameFilter, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="60"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             />

                    <!-- Message Filter -->
                    <TextBlock Text="Message:" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" Foreground="#7F8C8D"/>
                    <TextBox Padding="8" Margin="0,0,0,12" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderBrush="#E0E0E0"
                             Text="{Binding FilterViewModel.MessageFilter, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"/>

                    <!-- Severity Filter -->
                    <TextBlock Text="Severities:" FontSize="11" FontWeight="Bold" Margin="0,0,0,8" Foreground="#7F8C8D"/>
                    <Border BorderBrush="#E8ECEF" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,15" Background="#F8F9FA">
                        <ItemsControl ItemsSource="{Binding FilterViewModel.SeverityOptions}"
                                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                      mc:Ignorable="d"
                                      d:DataContext="{d:DesignInstance Type=WrapPanel}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" 
                                              IsChecked="{Binding IsChecked, Mode=TwoWay}" 
                                              Margin="0,3,12,3" 
                                              FontSize="11"
                                              FontWeight="SemiBold"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Facility Filter -->
                    <TextBlock Text="Facility:" FontSize="11" FontWeight="Bold" Margin="0,0,0,5" Foreground="#7F8C8D"/>
                    <ComboBox Padding="8" Margin="0,0,0,15" BorderBrush="#E0E0E0"
                              SelectedValuePath="Tag" 
                              SelectedValue="{Binding FilterViewModel.SelectedFacility, Mode=TwoWay}">
                        <ComboBoxItem Content="All" />
                        <ComboBoxItem Content="Kernel" Tag="0" />
                        <ComboBoxItem Content="User" Tag="1" />
                        <ComboBoxItem Content="Mail" Tag="2" />
                        <ComboBoxItem Content="Daemon" Tag="3" />
                        <ComboBoxItem Content="Auth" Tag="4" />
                        <ComboBoxItem Content="Syslog" Tag="5" />
                        <ComboBoxItem Content="LPR" Tag="6" />
                        <ComboBoxItem Content="News" Tag="7" />
                        <ComboBoxItem Content="Local0" Tag="16" />
                        <ComboBoxItem Content="Local1" Tag="17" />
                        <ComboBoxItem Content="Local2" Tag="18" />
                        <ComboBoxItem Content="Local3" Tag="19" />
                        <ComboBoxItem Content="Local4" Tag="20" />
                        <ComboBoxItem Content="Local5" Tag="21" />
                        <ComboBoxItem Content="Local6" Tag="22" />
                        <ComboBoxItem Content="Local7" Tag="23" />
                    </ComboBox>

                    <!-- Time Range Filter -->
                    <TextBlock Text="Time Range:" FontSize="11" FontWeight="Bold" Margin="0,15,0,5" Foreground="#7F8C8D"/>
					<StackPanel Margin="0,0,0,15">
                        <TextBlock Text="from:" FontSize="10" Foreground="#95A5A6" FontWeight="Bold"/>
                        <DatePicker SelectedDate="{Binding FilterViewModel.StartTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox ItemsSource="{Binding FilterViewModel.Hours}" SelectedItem="{Binding FilterViewModel.StartHour}" Width="50"/>
                            <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                            <ComboBox ItemsSource="{Binding FilterViewModel.Minutes}" SelectedItem="{Binding FilterViewModel.StartMinute}" Width="50"/>
                        </StackPanel>

                        <TextBlock Text="to:" FontSize="10" Foreground="#95A5A6" FontWeight="Bold"/>
                        <DatePicker SelectedDate="{Binding FilterViewModel.EndTime, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding FilterViewModel.Hours}" SelectedItem="{Binding FilterViewModel.EndHour}" Width="50"/>
                            <TextBlock Text=":" VerticalAlignment="Center" Margin="2,0"/>
                            <ComboBox ItemsSource="{Binding FilterViewModel.Minutes}" SelectedItem="{Binding FilterViewModel.EndMinute}" Width="50"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Auto Scroll -->
                    <CheckBox Content="Auto Scroll" IsChecked="{Binding FilterViewModel.AutoScroll}" Margin="2,0,0,20" FontWeight="SemiBold"/>

                    <!-- Clear Filters Button -->
                    <Button Content="Reset Filters" Background="#95A5A6" Foreground="White" Padding="10" FontWeight="Bold" BorderThickness="0"
                            Command="{Binding FilterViewModel.ClearFiltersCommand}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Splitter para redimensionar el panel lateral -->
        <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Background="#D0D0D0"
                      ShowsPreview="False"
                      Cursor="SizeWE"/>

        <!-- Contenido Derecho - Grid y Detalle -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- Grid Header Info -->
            <Border Grid.Row="0" Background="#E8ECEF" Padding="12,10" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
                <TextBlock Foreground="#2D3436" FontSize="11" FontWeight="SemiBold">
                    <Run Text="Showing "/>
                    <Run Text="{Binding FilteredMessages.Count, Mode=OneWay}" Foreground="#2980B9" FontWeight="Bold"/>
                    <Run Text=" from "/>
                    <Run Text="{Binding Messages.Count, Mode=OneWay}"/>
                    <Run Text=" in total"/>
                </TextBlock>
            </Border>

            <!-- Data Grid -->
            <!-- 2. Añadido x:Name="MyDataGrid" para que las referencias del ContextMenu funcionen -->
            <!-- DataGrid sin necesidad de x:Name para el menú contextual -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding FilteredMessages}"
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      Background="White"
                      GridLinesVisibility="All"
                      SelectedItem="{Binding SelectedMessage}"
                      HorizontalGridLinesBrush="#E8ECEF"
                      VerticalGridLinesBrush="#E8ECEF"
                      BorderThickness="0"
                      HeadersVisibility="Column"
                      AlternationCount="2"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <!-- MENÚ CONTEXTUAL: Vinculado al evento centralizado del code-behind -->
                <DataGrid.ContextMenu>
                    <ContextMenu MenuItem.Click="ColumnToggle_Click">
                        <MenuItem Header="Mostrar / Ocultar Columnas" IsEnabled="False" FontWeight="Bold"/>
                        <Separator/>
                        <MenuItem Header="Timestamp" IsCheckable="True" IsChecked="True" Tag="0"/>
                        <MenuItem Header="Received" IsCheckable="True" IsChecked="True" Tag="1"/>
                        <MenuItem Header="Hostname" IsCheckable="True" IsChecked="True" Tag="2"/>
                        <MenuItem Header="App" IsCheckable="True" IsChecked="True" Tag="3"/>
                        <MenuItem Header="PID" IsCheckable="True" IsChecked="True" Tag="4"/>
                        <MenuItem Header="Severity" IsCheckable="True" IsChecked="True" Tag="5"/>
                        <MenuItem Header="Facility" IsCheckable="True" IsChecked="True" Tag="6"/>
                        <MenuItem Header="Message" IsCheckable="True" IsChecked="True" Tag="7"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <DataGrid.Resources>
                    <!-- ESTILO DE CABECERAS: Reconstrucción limpia con líneas de separación y flechas funcionales -->
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F2F6"/>
                        <Setter Property="Foreground" Value="#2D3436"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridColumnHeader">
                                    <Grid>
                                        <!-- El secreto de las líneas divisorias: BorderThickness derecho e inferior con color visible (#CCCCCC) -->
                                        <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="0,0,1,1" 
                                    Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Texto de la columna -->
                                                <ContentPresenter Grid.Column="0" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      RecognizesAccessKey="True"/>

                                                <!-- Icono de la Flecha de Ordenación (Oculto por defecto) -->
                                                <Path x:Name="SortArrow"
                                          Grid.Column="1"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          Fill="#57606F"
                                          RenderTransformOrigin="0.5,0.5"
                                          Visibility="Collapsed"
                                          Data="M 0,4 L 4,0 L 8,4 Z">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Border>

                                        <!-- Zonas interactivas para permitir redimensionar las columnas con el ratón -->
                                        <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Width="1" Background="Transparent" Cursor="SizeWE"/>
                                        <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="1" Background="Transparent" Cursor="SizeWE"/>
                                    </Grid>

                                    <!-- Disparadores visuales de ordenación nativos de WPF -->
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="SortDirection" Value="Ascending">
                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="SortArrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="SortDirection" Value="Descending">
                                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="SortArrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="180"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <!-- COLUMNAS -->
                <DataGrid.Columns>
					<DataGridTextColumn x:Name="TimestampColumn"
                                        Header="Time Stamp"
                                        Binding="{Binding Timestamp, ConverterCulture={x:Static culture:CultureInfo.CurrentCulture}, StringFormat=\{0:yyyy-MM-dd HH:mm:ss.fff\}}"
                                        IsReadOnly="True"
                                        Width="150"/>
                    <DataGridTextColumn Header="Received"
                                        Binding="{Binding ReceivedTime, Converter={StaticResource UtcToLocalConverter}}"
                                        IsReadOnly="True"
                                        Width="150"/>
                    <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" SortMemberPath="Hostname" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="App" Binding="{Binding AppName}" SortMemberPath="AppName" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" SortMemberPath="ProcessId" Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Severity" Binding="{Binding SeverityName}" SortMemberPath="Severity" Width="85" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Facility" Binding="{Binding FacilityName}" SortMemberPath="Facility" Width="95" IsReadOnly="True"/>
					<DataGridTextColumn Header="Message"
                                        IsReadOnly="True"
                                        Binding="{Binding Message, Converter={StaticResource SingleLineConverter}}"
                                        Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <!-- Quitamos el Height. Ahora solo dejamos el recorte por si no cabe en el ancho de la pantalla -->
                                <Setter Property="TextWrapping" Value="NoWrap"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>

                <!-- ESTILO DE FILAS -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding BackgroundColor, Converter={StaticResource StringToColorBrushConverter}}"/>
                        <Setter Property="Foreground" Value="{Binding ForegroundColor, Converter={StaticResource StringToColorBrushConverter}}"/>
                        <Setter Property="FontWeight" Value="{Binding FontWeight}"/>
                        <Setter Property="FontStyle" Value="{Binding FontStyle}"/>
                        <Setter Property="Padding" Value="0,4"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding BackgroundColor}" Value="Transparent" />
                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex}" Value="1" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="#F9F9F9" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <GridSplitter Grid.Row="2" Height="4" HorizontalAlignment="Stretch" Background="#E0E0E0" ResizeBehavior="PreviousAndNext"/>

            <!-- Tarjeta Detalle de Mensaje -->
            <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#DCDDE1" BorderThickness="0,1,0,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10" DataContext="{Binding SelectedMessage}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="Origin:" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Hostname, FallbackValue='--'}" FontSize="11" FontWeight="Bold" Foreground="#2F3542" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="/" FontSize="11" Foreground="#A4B0BE" Margin="4,0"/>
                            <TextBlock Text="{Binding AppName, FallbackValue='--'}" FontSize="11" FontWeight="Bold" Foreground="#2980B9" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ProcessId, StringFormat='[{0}]', FallbackValue=''}" FontSize="11" Foreground="#7F8C8D" Margin="2,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="Level:" FontSize="10" FontWeight="Bold" Foreground="#7F8C8D" VerticalAlignment="Center"/>
                            <Border Margin="6,0,0,0" Padding="6,2" CornerRadius="3" Background="#F1F2F6" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SeverityName, FallbackValue='N/A'}" FontSize="10" FontWeight="ExtraBold" Foreground="#2E5BFF"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Text="Message detail" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold" Foreground="#A4B0BE" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBox Grid.Row="1" 
                             Text="{Binding SelectedMessageDetail, Mode=OneWay}"
                             FontFamily="Consolas" 
                             FontSize="12" 
                             Foreground="#2D3436"
                             Background="#F8F9FA" 
                             BorderBrush="#E8ECEF" 
                             BorderThickness="1" 
                             Padding="12" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>