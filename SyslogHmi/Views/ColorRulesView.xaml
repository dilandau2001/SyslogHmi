<UserControl x:Class="SyslogHmi.Views.ColorRulesView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:SyslogHmi.Converters"
             mc:Ignorable="d"
             Background="White">
    <UserControl.Resources>
        <converters:FriendlyColorNameToBrushConverter x:Key="ColorNameToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="280"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Rules List -->
		<Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0" Padding="12" Background="#F5F6FA">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<!-- 0: Título y Botón Añadir -->
					<RowDefinition Height="*"/>
					<!-- 1: Lista de Reglas de 2 Líneas -->
					<RowDefinition Height="Auto"/>
					<!-- 2: Botones de Control (Subir/Bajar/Eliminar) -->
				</Grid.RowDefinitions>

				<!-- Cabecera: Título y Botón "Nueva Regla" juntos -->
				<Grid Grid.Row="0" Margin="0,0,0,12">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Grid.Column="0" Text="Coloring Rules" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="#2D3436"/>
					<Button Grid.Column="1" Content="+ New Rule" Background="#27AE60" Foreground="White" Padding="12,5" FontWeight="Bold" BorderThickness="0"
							Command="{Binding ColorRuleViewModel.NewRuleCommand}"/>
				</Grid>

				<!-- Lista de Reglas (Estructura optimizada de 2 líneas) -->
				<ListBox Grid.Row="1" ItemsSource="{Binding ColorRuleViewModel.ColorRules}"
						 SelectedItem="{Binding ColorRuleViewModel.SelectedRule}"
						 BorderThickness="1" BorderBrush="#E0E0E0" Background="Transparent"
						 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border BorderBrush="#E8ECEF" BorderThickness="0,0,0,1" Padding="10,8" Background="White">
								<StackPanel>
									<!-- Línea 1: Nombre de la Regla -->
									<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="#2D3436" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>

									<!-- Línea 2: Background [Color] Foreground [Color] en la misma fila -->
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<!-- Componente Background -->
										<TextBlock Text="Background" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Center" Margin="0,0,6,0"/>
										<Rectangle Width="14" Height="14" Fill="{Binding Format.BackgroundColor}" Stroke="#BDC3C7" StrokeThickness="1" RadiusX="2" RadiusY="2" VerticalAlignment="Center" Margin="0,0,16,0"/>

										<!-- Componente Foreground -->
										<TextBlock Text="Foreground" FontSize="11" Foreground="#95A5A6" VerticalAlignment="Center" Margin="0,0,6,0"/>
										<Rectangle Width="14" Height="14" Fill="{Binding Format.ForegroundColor}" Stroke="#BDC3C7" StrokeThickness="1" RadiusX="2" RadiusY="2" VerticalAlignment="Center"/>
									</StackPanel>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
					<ListBox.ItemContainerStyle>
						<Style TargetType="ListBoxItem">
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
							<Setter Property="Padding" Value="0"/>
						</Style>
					</ListBox.ItemContainerStyle>
				</ListBox>

				<!-- Botones de Control Inferiores dispuestos horizontalmente -->
				<Grid Grid.Row="2" Margin="0,12,0,0">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Botón Subir -->
					<Button Grid.Column="0" Content="↑ Move up" Background="#3498DB" Foreground="White" Padding="6" Margin="0,0,4,0" BorderThickness="0"
							Command="{Binding ColorRuleViewModel.MoveRuleUpCommand}"/>

					<!-- Botón Bajar -->
					<Button Grid.Column="1" Content="↓ Move down" Background="#3498DB" Foreground="White" Padding="6" Margin="4,0,4,0" BorderThickness="0"
							Command="{Binding ColorRuleViewModel.MoveRuleDownCommand}"/>

					<!-- Botón Eliminar -->
					<Button Grid.Column="2" Content="Delete" Background="#E74C3C" Foreground="White" Padding="12,6" Margin="4,0,0,0" FontWeight="Bold" BorderThickness="0"
							Command="{Binding ColorRuleViewModel.DeleteRuleCommand}"/>
				</Grid>
			</Grid>
		</Border>

        <!-- Separator -->
        <GridSplitter Grid.Column="1" Width="5" Background="#D0D0D0" HorizontalAlignment="Center"/>

        <!-- Form Area -->
		<ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
			<Border Padding="20">
				<Grid DataContext="{Binding ColorRuleViewModel.FormViewModel}">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<!-- 0: Título Principal -->
						<RowDefinition Height="Auto"/>
						<!-- 1: Nombre de la Regla -->
						<RowDefinition Height="Auto"/>
						<!-- 2: Grupo de Condiciones -->
						<RowDefinition Height="Auto"/>
						<!-- 3: Grupo de Formato (Colores) -->
						<RowDefinition Height="Auto"/>
						<!-- 4: Botones de Acción -->
					</Grid.RowDefinitions>

					<!-- Título Principal -->
                    <TextBlock Grid.Row="0" Text="{Binding RuleName, StringFormat='Editar Regla', FallbackValue='Nueva Regla'}"
							   FontSize="16" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,20"/>

					<!-- Nombre de la Regla -->
					<Grid Grid.Row="1" Margin="0,0,0,20">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="100"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="Name:" VerticalAlignment="Center" FontWeight="Bold"/>
						<TextBox Grid.Column="1" Text="{Binding RuleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="10,0,0,0"/>
					</Grid>

					<!-- ================= GRUPO 1: CONDICIONES DE FILTRADO (FILAS HORIZONTALES) ================= -->
					<Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="5" CornerRadius="4" Padding="15" Margin="0,0,0,20">
						<StackPanel>
							<TextBlock Text="Filter conditions" FontSize="13" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,15"/>

							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<!-- Severidad -->
									<RowDefinition Height="Auto"/>
									<!-- Hostname -->
									<RowDefinition Height="Auto"/>
									<!-- Aplicación -->
									<RowDefinition Height="Auto"/>
									<!-- Facility -->
									<RowDefinition Height="Auto"/>
									<!-- Mensaje -->
									<RowDefinition Height="Auto"/>
									<!-- Process ID -->
									<RowDefinition Height="Auto"/>
									<!-- Message ID -->
								</Grid.RowDefinitions>

								<Grid.ColumnDefinitions>
									<!-- Col 0: El CheckBox activador con ancho fijo para que todos arranquen alineados -->
									<ColumnDefinition Width="140"/>
									<!-- Col 1: El control de entrada (TextBox o ItemsControl) que estira -->
									<ColumnDefinition Width="*"/>
									<!-- Col 2: El CheckBox de Case Sensitive (opcional) -->
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<!-- Severidad -->
								<CheckBox Grid.Row="0" Grid.Column="0" Content="Severity" IsChecked="{Binding SeverityFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<ItemsControl Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding SeverityOptions}" IsEnabled="{Binding SeverityFilterEnabled}" VerticalAlignment="Center" Margin="10,0,0,15">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<WrapPanel Orientation="Horizontal"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,0,15,0" VerticalAlignment="Center"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<!-- Hostname -->
								<CheckBox Grid.Row="1" Grid.Column="0" Content="Hostname" IsChecked="{Binding HostnameFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HostnameFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="6" IsEnabled="{Binding HostnameFilterEnabled}" VerticalAlignment="Center" Margin="10,0,15,15"/>
								<CheckBox Grid.Row="1" Grid.Column="2" Content="Case Sensitive" IsChecked="{Binding HostnameCaseSensitive, Mode=TwoWay}" IsEnabled="{Binding HostnameFilterEnabled}" VerticalAlignment="Center" Margin="0,0,0,15"/>

								<!-- Aplicación -->
								<CheckBox Grid.Row="2" Grid.Column="0" Content="Application" IsChecked="{Binding AppNameFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AppNameFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="6" IsEnabled="{Binding AppNameFilterEnabled}" VerticalAlignment="Center" Margin="10,0,15,15"/>
								<CheckBox Grid.Row="2" Grid.Column="2" Content="Case Sensitive" IsChecked="{Binding AppNameCaseSensitive, Mode=TwoWay}" IsEnabled="{Binding AppNameFilterEnabled}" VerticalAlignment="Center" Margin="0,0,0,15"/>

								<!-- Facility -->
								<CheckBox Grid.Row="3" Grid.Column="0" Content="Facility" IsChecked="{Binding FacilityFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<ItemsControl Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" ItemsSource="{Binding FacilityOptions}" IsEnabled="{Binding FacilityFilterEnabled}" VerticalAlignment="Center" Margin="10,0,0,15">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<WrapPanel Orientation="Horizontal"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,0,15,4" VerticalAlignment="Center"
													  IsEnabled="{Binding DataContext.FacilityFilterEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

								<!-- Mensaje -->
								<CheckBox Grid.Row="4" Grid.Column="0" Content="Message" IsChecked="{Binding MessageFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<TextBox Grid.Row="4" Grid.Column="1" Text="{Binding MessageFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="6" IsEnabled="{Binding MessageFilterEnabled}" VerticalAlignment="Center" Margin="10,0,15,15" AcceptsReturn="False" TextWrapping="NoWrap"/>
								<CheckBox Grid.Row="4" Grid.Column="2" Content="Case Sensitive" IsChecked="{Binding MessageCaseSensitive, Mode=TwoWay}" IsEnabled="{Binding MessageFilterEnabled}" VerticalAlignment="Center" Margin="0,0,0,15"/>

								<!-- Process ID -->
								<CheckBox Grid.Row="5" Grid.Column="0" Content="Process ID" IsChecked="{Binding PidFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,0,15"/>
								<TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PidFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="6" IsEnabled="{Binding PidFilterEnabled}" VerticalAlignment="Center" Margin="10,0,15,15" Grid.ColumnSpan="2"/>

								<!-- Message ID -->
								<CheckBox Grid.Row="6" Grid.Column="0" Content="Message ID" IsChecked="{Binding MsgIdFilterEnabled, Mode=TwoWay}" FontWeight="Bold" VerticalAlignment="Center"/>
								<TextBox Grid.Row="6" Grid.Column="1" Text="{Binding MsgIdFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="6" IsEnabled="{Binding MsgIdFilterEnabled}" VerticalAlignment="Center" Margin="10,0,15,0" Grid.ColumnSpan="2"/>
							</Grid>
						</StackPanel>
					</Border>

					<!-- ================= GRUPO 2: FORMATO VISUAL (COLORES) ================= -->
					<Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="5" CornerRadius="4" Padding="15" Margin="0,0,0,20">
						<StackPanel>
							<TextBlock Text="Filter Style" FontSize="13" FontWeight="Bold" Foreground="#2D3436" Margin="0,0,0,15"/>

							<StackPanel Orientation="Horizontal">
								<!-- Lado del Fondo -->
								<StackPanel Orientation="Horizontal" Margin="0,0,30,0">
									<TextBlock Text="Fondo:" VerticalAlignment="Center" FontWeight="Bold" Width="50"/>
									<ComboBox ItemsSource="{Binding AvailableColorItems}"
											  SelectedValuePath="Name" SelectedValue="{Binding SelectedBackgroundColor, Mode=TwoWay}"
											  Padding="6" Width="180">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal">
													<Rectangle Width="16" Height="16" Fill="{Binding ColorBrush}" Stroke="#999" StrokeThickness="1" Margin="0,0,8,0"/>
													<TextBlock Text="{Binding Name}" ToolTip="{Binding Name}"/>
												</StackPanel>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</StackPanel>

								<!-- Lado del Texto -->
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="Texto:" VerticalAlignment="Center" FontWeight="Bold" Width="50"/>
									<ComboBox ItemsSource="{Binding AvailableColorItems}"
											  SelectedValuePath="Name" SelectedValue="{Binding SelectedForegroundColor, Mode=TwoWay}"
											  Padding="6" Width="180">
										<ComboBox.ItemTemplate>
											<DataTemplate>
												<StackPanel Orientation="Horizontal">
													<Rectangle Width="16" Height="16" Fill="{Binding ColorBrush}" Stroke="#999" StrokeThickness="1" Margin="0,0,8,0"/>
													<TextBlock Text="{Binding Name}" ToolTip="{Binding Name}"/>
												</StackPanel>
											</DataTemplate>
										</ComboBox.ItemTemplate>
									</ComboBox>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</Border>

					<!-- Botones inferiores de Guardar / Cancelar -->
					<StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
						<Button Content="Guardar" Background="#27AE60" Foreground="White" Padding="20,8" Margin="0,0,10,0" FontWeight="Bold"
								Command="{Binding SaveRuleCommand}"/>
						<Button Content="Cancelar" Background="#95A5A6" Foreground="White" Padding="15,8"
								Command="{Binding CancelCommand}"/>
					</StackPanel>
				</Grid>
			</Border>
		</ScrollViewer>
    </Grid>
</UserControl>